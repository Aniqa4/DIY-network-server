// Prisma schema for the DIY Network Express backend.
// Mirrors the data model used by the NestJS reference server so both can
// share the same PostgreSQL database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  COOKING
  CRAFTING
  SEWING
  CROCHET
  KNITTING
  OTHER
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
}

// Purpose of a one-time password: confirming a new email, or authorising a
// password reset.
enum OtpPurpose {
  VERIFY
  RESET
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

// Lifecycle of an invitation to join the staff (admin/moderator) team.
enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  username  String  @unique
  password  String? // null for accounts created via Google
  googleId  String? @unique
  avatarUrl String?
  bio       String?

  role   Role    @default(USER)
  // A banned profile is hidden from the public and cannot log in or act.
  banned Boolean @default(false)

  emailVerified              Boolean   @default(false)
  verificationToken          String?   @unique
  verificationTokenExpiresAt DateTime?

  createdAt DateTime @default(now())

  posts            Post[]
  comments         Comment[]
  likes            Like[]
  saves            Save[]
  sentMessages     Message[]      @relation("sender")
  receivedMessages Message[]      @relation("receiver")
  following        Follow[]       @relation("follower")
  followers        Follow[]       @relation("following")
  notifications    Notification[] @relation("recipient")
  emailOtps        EmailOtp[]

  staffInvite    StaffInvite?  @relation("inviteRecipient")
  sentInvites    StaffInvite[] @relation("inviteSender")
  reportsMade    Report[]      @relation("reporter")
  reportsAgainst Report[]      @relation("reportedUser")
}

model Post {
  id          String   @id @default(cuid())
  title       String
  description String
  category    Category
  materials   String[]
  steps       String[]
  images      String[]
  views       Int      @default(0)
  // A banned post is hidden from public listings and detail pages.
  banned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  comments      Comment[]
  likes         Like[]
  saves         Save[]
  notifications Notification[]
  reports       Report[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  // One level of threading: a reply points at its parent comment. Deleting a
  // parent cascades to its replies.
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  replies  Comment[] @relation("CommentReplies")
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  @@unique([userId, postId])
}

model Save {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  @@unique([userId, postId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  sender   User   @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId String

  receiver   User   @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId String
}

model Follow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  follower   User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId String

  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String

  @@unique([followerId, followingId])
}

// One row represents a whole *bucket* of activity of the same kind on the
// same target (e.g. every like on a post) since it was last read, so the
// UI can show "Alice and 4 others liked your post" instead of 5 separate
// notifications.
model Notification {
  id       String           @id @default(cuid())
  type     NotificationType
  read     Boolean          @default(false)
  // Users who contributed to this bucket, most recent last.
  actorIds String[]

  recipient   User   @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String

  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A short-lived 6-digit code emailed to a user to verify their address or
// authorise a password reset. The code itself is stored hashed. At most one
// active row per (userId, purpose) — issuing a new code replaces the old.
model EmailOtp {
  id        String     @id @default(cuid())
  purpose   OtpPurpose
  codeHash  String
  attempts  Int        @default(0)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([userId, purpose])
}

// Access tokens carry a `jti`; logging out records it here until it would
// have expired anyway, so the auth middleware can reject it despite the
// token itself still being cryptographically valid.
model RevokedToken {
  jti       String   @id
  expiresAt DateTime
}

// An offer for a user to join the staff team as MODERATOR or ADMIN. One row
// per user (reused across re-invites): the admin flips it back to PENDING to
// invite again after a rejection or cancellation.
model StaffInvite {
  id     String       @id @default(cuid())
  role   Role // the offered role (MODERATOR or ADMIN)
  status InviteStatus @default(PENDING)

  user   User   @relation("inviteRecipient", fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  invitedBy   User   @relation("inviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A user-submitted report against either a post (content) or another user
// (profile). Exactly one of postId / reportedUserId is set.
model Report {
  id     String       @id @default(cuid())
  reason String
  status ReportStatus @default(PENDING)

  reporter   User   @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId String

  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String?

  reportedUser   User?   @relation("reportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reportedUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
