# Server
PORT=5000
# Comma-separated list of origins allowed by CORS (the Next.js dev server).
CORS_ORIGIN="http://localhost:3000"

# PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/diy_tutorials?schema=public"

JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# From your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME="replace-me"
CLOUDINARY_API_KEY="replace-me"
CLOUDINARY_API_SECRET="replace-me"

# Base URL of this API — used to build the link inside verification emails.
APP_URL="http://localhost:5000"

# The frontend origin — where Google OAuth redirects back to after sign-in.
CLIENT_URL="http://localhost:3000"

# SMTP credentials for sending verification emails. Works with Gmail SMTP,
# SendGrid, Mailtrap, Resend, etc. If left as "replace-me" the server logs
# the verification link to the console instead of sending an email.
EMAIL_HOST="replace-me"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="replace-me"
EMAIL_PASS="replace-me"
EMAIL_FROM="DIY Tutorials <no-reply@example.com>"

# From your OAuth app in Google Cloud Console (APIs & Services > Credentials).
GOOGLE_CLIENT_ID="replace-me"
GOOGLE_CLIENT_SECRET="replace-me"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/v1/auth/google/callback"
